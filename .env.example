# AI Job Search Agent - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for resume parsing, job matching, and resume tailoring)
OPENAI_API_KEY=your_openai_api_key_here

# SerpAPI Key (required for job search via Google Jobs)
SERPAPI_KEY=your_serpapi_key_here

# Application settings
SECRET_KEY=change_this_to_a_random_secret_key
DATABASE_URL=sqlite:///./job_agent.db

# Backend settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend settings
VITE_API_BASE_URL=http://localhost:8000
